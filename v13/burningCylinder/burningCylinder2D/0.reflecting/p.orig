FoamFile
{
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform  1e5; //1.33e4;

boundaryField
{
    #include "${FOAM_CASE}/0/bcParams"

    inlet
    {
        type            zeroGradient;
    }

    outlet
    {
        type            fixedValue;
        value           $internalField;

        // type            waveTransmissive;
        // fieldInf        1e5;
        // $waveTransmissiveParams;
    }

    wallsY
    {
        type            zeroGradient;

        // type            waveTransmissive;
        // fieldInf        1e5;
        // $waveTransmissiveParams;
    }

    cylinder
    {
        type            zeroGradient;
    }

    wallsZ
    {
        type            empty;
    }
}


// ************************************************************************* //
