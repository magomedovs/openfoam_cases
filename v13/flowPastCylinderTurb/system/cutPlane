FoamFile
{
    format          ascii;
    class           dictionary;
    location        "system";
    object          sample;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

type            surfaces;
libs            ("libsampling.so");

writeControl    writeTime;

surfaceFormat   vtk;

fields          ( p U mag(U) k epsilon );

interpolationScheme cellPoint;

surfaces
{
    zNormal
    {
        type            cutPlane;
        planeType       pointAndNormal;
        point           (0.50017 0.500317 0);
        normal          (0 0 1);
        interpolate     true;
    }
}


