// Which of the steps to run
castellatedMesh true;
snap            true;
addLayers       true;

geometry
{
    surfaceMesh
    {
        type triSurfaceMesh;
        name cylinder_stlSurface;

        file    "surfacemesh.stl";
    }

/*
    selection1.stl
    {
        type triSurfaceMesh;
        name selection1;
    }
*/

    // refinementBox
    // {
