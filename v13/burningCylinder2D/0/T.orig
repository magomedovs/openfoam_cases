FoamFile
{
    format      ascii;
    class       volScalarField;
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;

boundaryField
{
    #include "${FOAM_CASE}/0/bcParams"

    inlet
    {
        type            fixedValue;
        value           $internalField;
    }

    outlet
    {
        // type            waveTransmissive;
        // fieldInf        300;
        // $waveTransmissiveParams;

        type            advective;
        fieldInf        300;
        $waveTransmissiveParams;
    }

    wallsY
    {
        // type            zeroGradient;

        // type            waveTransmissive;
        // fieldInf        300;
        // $waveTransmissiveParams;

        type            advective;
        fieldInf        300;
        $waveTransmissiveParams;
    }

    cylinder
    {
        type            fixedValue;
        value           uniform 1500;
    }

    wallsZ
    {
        type            empty;
    }
}


// ************************************************************************* //
